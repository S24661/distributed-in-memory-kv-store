// CONSTRUCTOR / DESTRUCTOR
ReplicaClient::ReplicaClient(Store& store,
                             const std::string& primary_host,
                             int primary_port,
                             CommandCallback on_command)
    : store_(store)
    , primary_host_(primary_host)
    , primary_port_(primary_port)
    , on_command_(on_command)
{}

ReplicaClient::~ReplicaClient() { stop(); }

void ReplicaClient::start() {
    running_ = true;
    repl_thread_ = std::thread(&ReplicaClient::replication_thread, this);
}

void ReplicaClient::stop() {
    running_ = false;
    if (primary_fd_ >= 0) { close(primary_fd_); primary_fd_ = -1; }
    if (repl_thread_.joinable()) repl_thread_.join();
}

// REPLICATION THREAD BODY
void ReplicaClient::replication_thread() {
    while (running_) {
        state_ = ReplicaState::CONNECTING;
        std::cout << "[replica] Connecting to primary "
                  << primary_host_ << ":" << primary_port_ << "...\n";

        int fd = connect_to_primary();
        if (fd < 0) {
            std::cerr << "[replica] Connection failed, retrying in 2s\n";
            std::this_thread::sleep_for(std::chrono::seconds(2));
            continue;
        }
        primary_fd_ = fd;
        std::cout << "[replica] Connected to primary\n";

        // Send PSYNC 
        state_ = ReplicaState::SYNCING;
        if (!do_psync(fd)) {
            std::cerr << "[replica] PSYNC failed\n";
            close(fd); primary_fd_ = -1;
            std::this_thread::sleep_for(std::chrono::seconds(2));
            continue;
        }

        // Stream commands
        state_ = ReplicaState::STREAMING;
        std::cout << "[replica] Streaming from primary (offset="
                  << repl_offset_ << ")\n";
        streaming_loop(fd);

        // Streaming loop exited = primary disconnected
        std::cerr << "[replica] Primary disconnected, retrying in 2s\n";
        close(fd); primary_fd_ = -1;
        state_ = ReplicaState::DISCONNECTED;
        std::this_thread::sleep_for(std::chrono::seconds(2));
    }
}

// CONNECT TO PRIMARY
int ReplicaClient::connect_to_primary() {
    // Resolve hostname to IP
    struct addrinfo hints{}, *result;
    hints.ai_family   = AF_INET;
    hints.ai_socktype = SOCK_STREAM;

    std::string port_str = std::to_string(primary_port_);
    if (getaddrinfo(primary_host_.c_str(), port_str.c_str(),
                    &hints, &result) != 0) {
        std::cerr << "[replica] getaddrinfo failed for "
                  << primary_host_ << "\n";
        return -1;
    }

    int fd = socket(AF_INET, SOCK_STREAM, 0);
    if (fd < 0) { freeaddrinfo(result); return -1; }

    // Set connect timeout (5 seconds)
    struct timeval tv{5, 0};
    setsockopt(fd, SOL_SOCKET, SO_RCVTIMEO, &tv, sizeof(tv));
    setsockopt(fd, SOL_SOCKET, SO_SNDTIMEO, &tv, sizeof(tv));

    if (connect(fd, result->ai_addr, result->ai_addrlen) < 0) {
        std::cerr << "[replica] connect() failed: " << strerror(errno) << "\n";
        freeaddrinfo(result);
        close(fd);
        return -1;
    }

    freeaddrinfo(result);

    // Remove timeout for streaming 
    tv = {0, 0};
    setsockopt(fd, SOL_SOCKET, SO_RCVTIMEO, &tv, sizeof(tv));
    setsockopt(fd, SOL_SOCKET, SO_SNDTIMEO, &tv, sizeof(tv));

    return fd;
}

// READ HELPERS
bool ReplicaClient::read_exact(int fd, char* buf, size_t n) {
    size_t total = 0;
    while (total < n) {
        ssize_t r = recv(fd, buf + total, n - total, 0);
        if (r <= 0) return false;
        total += r;
    }
    return true;
}

bool ReplicaClient::read_line(int fd, std::string& out) {
    out.clear();
    char c;
    while (true) {
        ssize_t r = recv(fd, &c, 1, 0);
        if (r <= 0) return false;
        if (c == '\r') {
            recv(fd, &c, 1, 0);  // consume \n
            return true;
        }
        out += c;
    }
}

// DO PSYNC — Handshake with primary
bool ReplicaClient::do_psync(int fd) {
    std::string psync_cmd;
    if (repl_id_.empty() || repl_offset_ == 0) {
        psync_cmd = "*3\r\n$5\r\nPSYNC\r\n$1\r\n?\r\n$2\r\n-1\r\n";
    } else {
        psync_cmd = "*3\r\n$5\r\nPSYNC\r\n$"
                  + std::to_string(repl_id_.size()) + "\r\n"
                  + repl_id_ + "\r\n$"
                  + std::to_string(std::to_string(repl_offset_).size()) + "\r\n"
                  + std::to_string(repl_offset_) + "\r\n";
    }

    if (send(fd, psync_cmd.c_str(), psync_cmd.size(), MSG_NOSIGNAL) < 0)
        return false;

    // Read response
    std::string line;
    if (!read_line(fd, line)) return false;

    if (line.substr(0, 12) == "+FULLRESYNC ") {
        // Parse: +FULLRESYNC <repl_id> <offset>
        std::istringstream ss(line.substr(12));
        ss >> repl_id_;
        ss >> repl_offset_;
        std::cout << "[replica] Full resync, repl_id=" << repl_id_
                  << " offset=" << repl_offset_ << "\n";
        return receive_rdb(fd);

    } else if (line.substr(0, 9) == "+CONTINUE") {
        // Partial resync — primary will stream backlog
        std::cout << "[replica] Partial resync continuing\n";
        return true;

    } else {
        std::cerr << "[replica] Unexpected PSYNC response: " << line << "\n";
        return false;
    }
}

// RECEIVE RDB — Load full snapshot from primary
bool ReplicaClient::receive_rdb(int fd) {
    std::cout << "[replica] Receiving RDB snapshot...\n";

    // Read "$<len>" line
    std::string line;
    if (!read_line(fd, line)) return false;
    if (line.empty() || line[0] != '$') {
        std::cerr << "[replica] Expected RDB length, got: " << line << "\n";
        return false;
    }

    size_t rdb_len;
    try { rdb_len = (size_t)std::stoll(line.substr(1)); }
    catch (...) { return false; }

    // Read exactly rdb_len bytes
    std::vector<uint8_t> rdb_data(rdb_len);
    if (!read_exact(fd, (char*)rdb_data.data(), rdb_len)) {
        std::cerr << "[replica] Failed to read RDB data\n";
        return false;
    }

    // Load into store 
    store_.flushall();
    bool ok = RDB::deserialize(rdb_data, store_);
    if (ok)
        std::cout << "[replica] RDB loaded: " << store_.dbsize() << " keys\n";
    return ok;
}

// STREAMING LOOP — Apply commands from primary
void ReplicaClient::streaming_loop(int fd) {
    RespParser parser;
    std::string buf;
    char tmp[4096];

    while (running_) {
        ssize_t n = recv(fd, tmp, sizeof(tmp), 0);
        if (n <= 0) {
            if (n < 0 && (errno == EAGAIN || errno == EWOULDBLOCK)) continue;
            break;  // disconnected
        }

        buf.append(tmp, n);
        repl_offset_ += n;

        // Parse and execute all complete commands in buf
        while (true) {
            size_t consumed = 0;
            auto cmd = parser.parse(buf, consumed);
            if (cmd.empty()) break;
            buf.erase(0, consumed);

            if (cmd.size() == 1 && cmd[0] == "__ERROR__") continue;
            if (cmd.empty()) continue;

            // Uppercase command name
            for (char& c : cmd[0]) c = toupper(c);

            // Apply command to our local store
            if (cmd[0] == "SET" && cmd.size() >= 3) {
                std::optional<int> ttl;
                for (size_t i = 3; i + 1 < cmd.size(); i++)
                    if (cmd[i] == "EX") ttl = std::stoi(cmd[i+1]);
                store_.set(cmd[1], cmd[2], ttl);

            } else if (cmd[0] == "DEL" && cmd.size() >= 2) {
                for (size_t i = 1; i < cmd.size(); i++)
                    store_.del(cmd[i]);

            } else if (cmd[0] == "EXPIRE" && cmd.size() == 3) {
                store_.expire(cmd[1], std::stoi(cmd[2]));

            } else if (cmd[0] == "MSET" && cmd.size() >= 3) {
                for (size_t i = 1; i + 1 < cmd.size(); i += 2)
                    store_.set(cmd[i], cmd[i+1]);

            } else if (cmd[0] == "FLUSHALL") {
                store_.flushall();

            } else if (cmd[0] == "PING") {
                // Primary sends PING as heartbeat — send PONG back
                std::string pong = "+PONG\r\n";
                send(fd, pong.c_str(), pong.size(), MSG_NOSIGNAL);
                continue;
            }

            // Notify caller 
            if (on_command_) on_command_(cmd);
        }
    }
}

// GET INFO
ReplicaClient::Info ReplicaClient::get_info() const {
    Info info;
    info.primary_host    = primary_host_;
    info.primary_port    = primary_port_;
    info.primary_repl_id = repl_id_;
    info.repl_offset     = repl_offset_;

    switch (state_.load()) {
        case ReplicaState::DISCONNECTED: info.state = "disconnected"; break;
        case ReplicaState::CONNECTING:   info.state = "connecting";   break;
        case ReplicaState::SYNCING:      info.state = "sync";         break;
        case ReplicaState::STREAMING:    info.state = "connected";    break;
    }
    return info;
}
